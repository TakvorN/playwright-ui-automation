{
  "name": "playwright-ui-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:chromium": "playwright test --project=chromium",
    "test:smoke": "playwright test --grep @smoke",
    "test:headed": "playwright test --project=chromium --headed",
    "report": "playwright show-report",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t playwright-ui-automation .",
    "docker:test": "docker run --rm --ipc=host playwright-ui-automation",
    "docker:test:chromium": "docker run --rm --ipc=host playwright-ui-automation npm run test:chromium",
    "docker:type-check": "docker run --rm playwright-ui-automation npm run type-check"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
